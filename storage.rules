rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Avatar uploads — only the user can read/write their own avatar
    match /avatars/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Playlist covers — only the owner can write, anyone authenticated can read
    match /playlist-covers/{userId}/{playlistId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
